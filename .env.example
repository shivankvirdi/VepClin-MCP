# Copy this file to .env and fill in the real value. .env is gitignored.

# https://openrouter.ai/
OPENROUTER_API_KEY=sk-or...

# https://www.ncbi.nlm.nih.gov/account/settings/ 
(optional: raises Entrez rate limit from 3/sec to 10/sec)
NCBI_API_KEY=

# Recommended for consistent NCBI requests
NCBI_EMAIL=your-email@example.com